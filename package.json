{
  "name": "@cocaxcode/ai-context-inspector",
  "version": "0.3.1",
  "description": "Scan any project to discover its complete AI ecosystem: MCP servers, tools, context files, skills, memories. Generates an interactive HTML dashboard. Works as CLI and MCP server.",
  "type": "module",
  "bin": {
    "ai-context-inspector": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js -- --mcp",
    "serve:report": "node serve-report.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-context",
    "ai-inspector",
    "ai-tools",
    "mcp-introspection",
    "claude",
    "cursor",
    "windsurf",
    "copilot",
    "gemini",
    "codex",
    "aider",
    "cline",
    "dashboard",
    "html-report",
    "context-files",
    "skills",
    "ai-ecosystem"
  ],
  "author": "cocaxcode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cocaxcode/ai-context-inspector.git"
  },
  "homepage": "https://github.com/cocaxcode/ai-context-inspector#readme",
  "bugs": {
    "url": "https://github.com/cocaxcode/ai-context-inspector/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.2.0"
  }
}
